# aleph.env.docker — environment for Aleph services (api, worker, ui-API-target, ingest-file, ftm-analyze, ftm-translate)
# Copy to aleph.env.docker (gitignored). bin/dev-init replaces ALEPH_SECRET_KEY with a per-workspace value.
#
# Inside the Docker network, services use internal hostnames + internal default ports.
# Only the HOST-mapped ports differ per workspace (set in .env.ports).

# Generated per workspace by bin/dev-init. Do not commit.
ALEPH_SECRET_KEY=replace-me-via-bin-dev-init

# ---- Single-user dev mode (skip auth) ----
ALEPH_SINGLE_USER=true
ALEPH_ADMINS=admin@example.com

# ---- Service URLs (internal Docker network) ----
ALEPH_DATABASE_URI=postgresql://aleph:aleph@postgres/aleph
ALEPH_ELASTICSEARCH_URL=http://elasticsearch:9200
ALEPH_REDIS_URL=redis://redis:6379

# ---- Optional debug ----
ALEPH_DEBUG=false
