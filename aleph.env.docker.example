# aleph.env.docker — environment for Aleph services
# (api, worker, ui-API-target, ingest-file, ftm-analyze, ftm-translate)
#
# Copy to aleph.env.docker (gitignored). bin/dev-init substitutes
# ALEPH_SECRET_KEY and ALEPH_UI_URL with per-workspace values.
#
# Inside the Docker network, services use internal hostnames + internal default
# ports. Only the HOST-mapped ports differ per workspace (set in .env.ports).

# Generated per workspace by bin/dev-init. Do not commit.
ALEPH_SECRET_KEY=replace-me-via-bin-dev-init

# ---- User-facing URL ----
# Aleph embeds this URL in API responses (e.g. signed token URLs for the
# inline PDF viewer + Download button). The upstream default is
# http://localhost:8080/ — that's the UI container's INTERNAL port, which the
# browser cannot reach on the host, so PDF preview and Download silently break.
# bin/dev-init replaces this with the actual host-facing UI port.
ALEPH_UI_URL=http://localhost:8000/

# ---- Auth mode ----
# ALEPH_SINGLE_USER=true bypasses authentication and attributes every action to
# a synthetic "Aleph" pseudo-user. That breaks audit attribution — every
# collection / document / note shows "Created by: Aleph" regardless of who's
# logged in. Default to false; bootstrap admins via `aleph createuser` after
# bringing the stack up.
ALEPH_SINGLE_USER=false
ALEPH_ADMINS=admin@example.com

# ---- Service URLs (internal Docker network) ----
ALEPH_DATABASE_URI=postgresql://aleph:aleph@postgres/aleph
ALEPH_ELASTICSEARCH_URL=http://elasticsearch:9200
ALEPH_REDIS_URL=redis://redis:6379

# ---- Worker-side config (ingest-file, ftm-analyze, ftm-translate) ----
# The openaleph server image (used by api/worker) bakes these defaults into its
# Dockerfile ENV. The separate ingest-file / ftm-analyze / ftm-translate images
# do NOT, so without these every ingest job dies with:
#   sqlalchemy.exc.NoSuchModuleError: Can't load plugin: sqlalchemy.dialects:memory
# (followthemoney falls back to memory:// when no FTM_FRAGMENTS_URI is set.)
FTM_FRAGMENTS_URI=postgresql://aleph:aleph@postgres/aleph
PROCRASTINATE_DB_URI=postgresql://aleph:aleph@postgres/aleph
OPENALEPH_ELASTICSEARCH_URI=http://elasticsearch:9200/

# ---- Optional debug ----
ALEPH_DEBUG=false
