# project_y server environment
# Copy to server/.env (gitignored). To share across Conductor workspaces, move the
# real file to ~/projects/project_y/server/.env and bin/dev-init will symlink to it.

# ---- LLM endpoint (env-var driven, single client interface) ----
# Dev / demo: OpenRouter or Vertex serving Gemma 4
# OLAF prod: vLLM endpoint (post-conference)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-replace-me
LLM_MODEL=google/gemma-4-27b-it

# Optional fallback / backup model (used if primary fails the eval harness)
# LLM_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct

# ---- Aleph endpoint (set by bin/dev-init from per-workspace ports) ----
# Sourced from .env.ports at runtime; no need to duplicate here.
# ALEPH_BASE_URL=http://localhost:${ALEPH_API_PORT}/api/2

# ---- Performance budget (Spike 3 outputs; default values, tune per spike) ----
RETRIEVAL_BUDGET=200       # max docs surfaced from Aleph per hypothesis
DOC_READ_CAP=20            # max docs deeply read per hypothesis
CHUNKING_POLICY=page-aware # how long docs are sliced (page-aware | fixed-2k | semantic)
RECALL_TARGET=0.80         # % of expected-relevant docs the agent should surface

# ---- Audit log ----
AUDIT_DB_PATH=./data/audit.sqlite

# ---- Observability ----
LOG_LEVEL=INFO
# LANGSMITH tracing is OPT-IN (off by default for air-gap compatibility)
# LANGCHAIN_TRACING_V2=false
