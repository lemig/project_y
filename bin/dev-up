#!/usr/bin/env bash
# dev-up — Start the project_y dev environment for THIS workspace.
#
# Brings up the Aleph stack (Postgres + Elasticsearch + Redis + workers)
# at port offsets specific to this Conductor workspace. Containers and
# volumes are isolated per workspace via COMPOSE_PROJECT_NAME.
#
# project_y's own FastAPI agent service is added in docker-compose.yml
# once the Python project is scaffolded (TODO).

set -euo pipefail
cd "$(dirname "$0")/.."

if [ ! -f .env.ports ]; then
  echo "Run bin/dev-init first."
  exit 1
fi

# Source .env.ports to get COMPOSE_PROJECT_NAME and per-workspace ports
# shellcheck source=/dev/null
source .env.ports
export COMPOSE_PROJECT_NAME PROJECT_ROOT WORKSPACE_NAME
export API_PORT UI_PORT
export ALEPH_POSTGRES_PORT ALEPH_ES_PORT ALEPH_REDIS_PORT ALEPH_API_PORT ALEPH_UI_PORT
export ALEPH_POSTGRES_URL ALEPH_ES_URL ALEPH_REDIS_URL

# Compose files: aleph stack always; project_y stack only if file exists
COMPOSE_ARGS="-f docker-compose.aleph.yml"
if [ -f docker-compose.yml ]; then
  COMPOSE_ARGS="${COMPOSE_ARGS} -f docker-compose.yml"
fi
# Compose's automatic loading of docker-compose.override.yml is suppressed
# whenever -f is used, so opt back in explicitly when one is present.
if [ -f docker-compose.override.yml ]; then
  COMPOSE_ARGS="${COMPOSE_ARGS} -f docker-compose.override.yml"
fi

echo "Starting project_y dev environment for workspace '${WORKSPACE_NAME}'..."
echo "  COMPOSE_PROJECT_NAME = ${COMPOSE_PROJECT_NAME}"
echo ""
echo "  → Open in your browser: http://localhost:${ALEPH_UI_PORT}"
echo ""
echo "  Other endpoints:"
echo "    Aleph API     → http://localhost:${ALEPH_API_PORT}/api/2/"
echo "    Postgres      → localhost:${ALEPH_POSTGRES_PORT}"
echo "    Elasticsearch → ${ALEPH_ES_URL}"
echo "    Redis         → redis://localhost:${ALEPH_REDIS_PORT}"
echo ""

# shellcheck disable=SC2086
docker compose ${COMPOSE_ARGS} up -d --remove-orphans

# Detect port-drift from out-of-band `docker compose ... up --force-recreate`
# runs that didn't source .env.ports first. Without ALEPH_API_PORT exported,
# compose falls back to the default in docker-compose.aleph.yml and api ends up
# bound to the wrong host port until the next clean dev-down/dev-up cycle.
ACTUAL_API=$(docker inspect "${COMPOSE_PROJECT_NAME}-api-1" \
  --format '{{(index (index .NetworkSettings.Ports "8000/tcp") 0).HostPort}}' 2>/dev/null || true)
if [ -n "${ACTUAL_API:-}" ] && [ "${ACTUAL_API}" != "${ALEPH_API_PORT}" ]; then
  echo ""
  echo "Notice: api was bound to host port ${ACTUAL_API}, expected ${ALEPH_API_PORT}."
  echo "        Recreating api to restore the correct mapping..."
  # shellcheck disable=SC2086
  docker compose ${COMPOSE_ARGS} up -d --force-recreate api
fi

echo ""
echo "Stack is starting up. First start runs DB migrations (~1-2 min)."
echo "Use 'bin/dev-status' to see health, 'bin/dev-down' to stop."
echo ""
echo "Open in browser when ready:  http://localhost:${ALEPH_UI_PORT}"
