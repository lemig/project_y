#!/usr/bin/env bash
# dev-init — Set up a project_y workspace for parallel development with Conductor.
#
# Reads CONDUCTOR_PORT (set per-workspace by Conductor) and derives all ports
# at offsets so multiple project_y workspaces can run simultaneously without
# collision. Containers + Docker volumes are scoped per workspace via
# COMPOSE_PROJECT_NAME.
#
# Port allocation (offsets from CONDUCTOR_PORT base).
# Low offsets are user-facing; high offsets are infrastructure.
#   +0   Aleph UI            (THE entry point; what you open in the browser)
#   +1   Aleph API           (what project_y will talk to)
#   +2   project_y API       (reserved; will be used once project_y scaffolds)
#   +3   project_y dev UI    (reserved)
#   +10  Aleph Postgres
#   +11  Aleph Elasticsearch
#   +12  Aleph Redis
#
# Without Conductor, defaults to base 8000.
#
# Outputs:
#   .env.ports       — sourced by dev-up, dev-down, dev-status (gitignored)
#   server/.env      — symlinked to ~/projects/project_y/server/.env if present,
#                      otherwise copied from server/.env.example (gitignored)
#   aleph.env.docker — copied from aleph.env.docker.example with a fresh
#                      ALEPH_SECRET_KEY (gitignored)

set -euo pipefail
cd "$(dirname "$0")/.."
PROJECT_ROOT="$(pwd)"
WORKSPACE_NAME="$(basename "$PROJECT_ROOT")"

# --- Port allocation ---
BASE_PORT="${CONDUCTOR_PORT:-}"
if [ -n "$BASE_PORT" ]; then
  ALEPH_UI_PORT=$((BASE_PORT))         # +0: user-facing entry point
  ALEPH_API_PORT=$((BASE_PORT + 1))    # +1: what project_y talks to
  API_PORT=$((BASE_PORT + 2))          # +2: project_y API (future)
  UI_PORT=$((BASE_PORT + 3))           # +3: project_y dev UI (future)
  ALEPH_POSTGRES_PORT=$((BASE_PORT + 10))
  ALEPH_ES_PORT=$((BASE_PORT + 11))
  ALEPH_REDIS_PORT=$((BASE_PORT + 12))
else
  ALEPH_UI_PORT="${ALEPH_UI_PORT:-8000}"
  ALEPH_API_PORT="${ALEPH_API_PORT:-8001}"
  API_PORT="${API_PORT:-8002}"
  UI_PORT="${UI_PORT:-8003}"
  ALEPH_POSTGRES_PORT="${ALEPH_POSTGRES_PORT:-8010}"
  ALEPH_ES_PORT="${ALEPH_ES_PORT:-8011}"
  ALEPH_REDIS_PORT="${ALEPH_REDIS_PORT:-8012}"
fi

# Distinct compose project name per workspace = container/volume isolation.
# Use the base CONDUCTOR_PORT (= ALEPH_UI_PORT now) so the project name is
# stable as the workspace's "primary" port.
COMPOSE_PROJECT="project_y-${ALEPH_UI_PORT}"

# --- Write .env.ports (sourced by dev-up, dev-down, dev-status) ---
cat > .env.ports <<EOF
# Generated by bin/dev-init. Do not edit by hand. Re-run dev-init to regenerate.
# Workspace: ${WORKSPACE_NAME}
COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT}
PROJECT_ROOT=${PROJECT_ROOT}
WORKSPACE_NAME=${WORKSPACE_NAME}

# Aleph stack (per-workspace instance, port-offset)
# +0 = user-facing UI; +1 = API; +2/+3 reserved for project_y; +10..+12 = infra
ALEPH_UI_PORT=${ALEPH_UI_PORT}
ALEPH_API_PORT=${ALEPH_API_PORT}
API_PORT=${API_PORT}
UI_PORT=${UI_PORT}
ALEPH_POSTGRES_PORT=${ALEPH_POSTGRES_PORT}
ALEPH_ES_PORT=${ALEPH_ES_PORT}
ALEPH_REDIS_PORT=${ALEPH_REDIS_PORT}

# Convenience URLs for local clients (host network, not Docker network)
ALEPH_UI_URL=http://localhost:${ALEPH_UI_PORT}
ALEPH_API_URL=http://localhost:${ALEPH_API_PORT}/api/2
ALEPH_POSTGRES_URL=postgresql://aleph:aleph@localhost:${ALEPH_POSTGRES_PORT}/aleph
ALEPH_ES_URL=http://localhost:${ALEPH_ES_PORT}
ALEPH_REDIS_URL=redis://localhost:${ALEPH_REDIS_PORT}
EOF

echo "Ports configured for workspace '${WORKSPACE_NAME}':"
echo "  COMPOSE_PROJECT_NAME = ${COMPOSE_PROJECT}"
echo "  ALEPH_UI_PORT (+0)   = ${ALEPH_UI_PORT}   ← open this in your browser"
echo "  ALEPH_API_PORT (+1)  = ${ALEPH_API_PORT}"
echo "  API_PORT (+2)        = ${API_PORT}   (project_y, reserved)"
echo "  UI_PORT (+3)         = ${UI_PORT}   (project_y dev UI, reserved)"
echo "  ALEPH_POSTGRES_PORT  = ${ALEPH_POSTGRES_PORT}"
echo "  ALEPH_ES_PORT        = ${ALEPH_ES_PORT}"
echo "  ALEPH_REDIS_PORT     = ${ALEPH_REDIS_PORT}"

# --- server/.env: symlink to shared if available, else copy from example ---
SHARED_ENV="${HOME}/projects/project_y/server/.env"
LOCAL_ENV="${PROJECT_ROOT}/server/.env"
if [ -L server/.env ]; then
  echo "server/.env is already symlinked — skipping."
elif [ -f "$SHARED_ENV" ] && [ "$SHARED_ENV" != "$LOCAL_ENV" ]; then
  rm -f server/.env
  ln -s "$SHARED_ENV" server/.env
  echo "Symlinked server/.env → $SHARED_ENV"
elif [ ! -f server/.env ]; then
  if [ -f server/.env.example ]; then
    cp server/.env.example server/.env
    echo "Created server/.env from .env.example — edit with your API key."
    echo "  (Tip: move it to ${SHARED_ENV} to share across workspaces.)"
  else
    echo "Warning: server/.env.example not found. Create server/.env manually."
  fi
else
  echo "server/.env already exists — skipping."
fi

# --- aleph.env.docker: per-workspace, generate fresh ALEPH_SECRET_KEY + ALEPH_UI_URL ---
if [ ! -f aleph.env.docker ]; then
  if [ ! -f aleph.env.docker.example ]; then
    echo "Warning: aleph.env.docker.example not found. Skipping aleph.env.docker setup."
  else
    cp aleph.env.docker.example aleph.env.docker
    # Generate a per-workspace secret key (32 random bytes hex)
    SECRET=$(openssl rand -hex 32 2>/dev/null || python3 -c "import secrets; print(secrets.token_hex(32))")
    # macOS sed needs '' after -i; Linux sed doesn't. Try BSD form first, fall back.
    if sed -i '' "s|^ALEPH_SECRET_KEY=.*|ALEPH_SECRET_KEY=${SECRET}|" aleph.env.docker 2>/dev/null; then
      :
    else
      sed -i "s|^ALEPH_SECRET_KEY=.*|ALEPH_SECRET_KEY=${SECRET}|" aleph.env.docker
    fi
    # Substitute ALEPH_UI_URL with this workspace's host-facing UI port. The
    # default in the example is the UI container's internal port (8080), which
    # the browser cannot reach; using the host port makes PDF preview / Download
    # work end-to-end.
    if sed -i '' "s|^ALEPH_UI_URL=.*|ALEPH_UI_URL=http://localhost:${ALEPH_UI_PORT}/|" aleph.env.docker 2>/dev/null; then
      :
    else
      sed -i "s|^ALEPH_UI_URL=.*|ALEPH_UI_URL=http://localhost:${ALEPH_UI_PORT}/|" aleph.env.docker
    fi
    echo "Created aleph.env.docker with a fresh ALEPH_SECRET_KEY and ALEPH_UI_URL for this workspace."
  fi
else
  echo "aleph.env.docker already exists — skipping."
fi

# --- Data directory (per-workspace; gitignored) ---
mkdir -p data
[ -f data/.gitkeep ] || touch data/.gitkeep

echo ""
echo "Done. Run bin/dev-up to start the Aleph stack + project_y services."
